{
  "id": "hero",
  "type": "SharedSlice",
  "name": "Hero",
  "description": "Hero banner section with title, subtitle, background image, and descriptive footer text",
  "variations": [
    {
      "id": "default",
      "name": "Default",
      "docURL": "...",
      "version": "initial",
      "description": "Default hero variation",
      "imageUrl": "",
      "primary": {
        "title": {
          "type": "StructuredText",
          "config": {
            "label": "Title",
            "single": "heading1",
            "placeholder": "Enter hero title"
          }
        },
        "subtitle": {
          "type": "StructuredText",
          "config": {
            "label": "Subtitle",
            "single": "paragraph",
            "placeholder": "Enter hero subtitle"
          }
        },
        "backgroundImage": {
          "type": "Image",
          "config": {
            "label": "Background Image",
            "constraint": {
              "width": 1920,
              "height": 1080
            }
          }
        },
        "footerText": {
          "type": "StructuredText",
          "config": {
            "label": "Footer Text",
            "placeholder": "Enter footer descriptive text",
            "allowTargetBlank": true,
            "single": "paragraph"
          }
        }
      },
      "items": {}
    }
  ]
}