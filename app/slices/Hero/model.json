        "cta": {
          "type": "Link",
          "config": {
            "label": "CTA",
            "placeholder": "",
            "select": null,
            "allowTargetBlank": true,
            "allowText": true,
            "repeat": false
          }
        },
        "footerText": {
          "type": "Text",
          "config": {
            "label": "Additional text",
            "placeholder": "Enter footer descriptive text"
          }
        },
        "backgroundImage": {
          "type": "Image",
          "config": {
            "label": "Background Image",
            "constraint": { "width": 1200, "height": 800 },
            "thumbnails": [
              { "name": "Mobile", "width": 800, "height": 1000 }
            ]
          }
        }
      },
      "items": {}
    }
  ]
