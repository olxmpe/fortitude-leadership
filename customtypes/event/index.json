{
  "format": "custom",
  "id": "event",
  "label": "Event",
  "repeatable": true,
  "status": true,
  "json": {
    "Main": {
      "uid": {
        "type": "UID",
        "config": {
          "label": "Identifiant unique de l'événement",
          "placeholder": "d-day-1"
        }
      },
      "image": {
        "type": "Image",
        "config": {
          "label": "Image mise en avant",
          "constraint": {
            "width": 800,
            "height": 600
          }
        }
      },
      "title": {
        "type": "Text",
        "config": {
          "label": "Nom de l'événement",
          "placeholder": "D-Day challenge #01"
        }
      },
      "description": {
        "type": "Text",
        "config": {
          "label": "Description",
          "placeholder": "Un programme de 48h, immersif et engageant"
        }
      },
      "cta": {
        "type": "Link",
        "config": {
          "label": "CTA",
          "placeholder": "Déposez votre candidature",
          "select": null,
          "allowTargetBlank": true,
          "allowText": true,
          "repeat": false
        }
      },
      "flyer": {
        "type": "Link",
        "config": {
          "label": "Plaquette",
          "placeholder": "",
          "select": "media",
          "allowText": true
        }
      },
      "start": {
        "type": "Date",
        "config": {
          "label": "Date de début",
          "placeholder": ""
        }
      },
      "end": {
        "type": "Date",
        "config": {
          "label": "Date de fin",
          "placeholder": ""
        }
      },
      "location": {
        "type": "Text",
        "config": {
          "label": "Lieu",
          "placeholder": ""
        }
      },
      "format": {
        "type": "Text",
        "config": {
          "label": "format",
          "placeholder": ""
        }
      },
      "attendees_count": {
        "type": "Text",
        "config": {
          "label": "Nombre de participants",
          "placeholder": ""
        }
      },
      "slices": {
        "type": "Slices",
        "fieldset": "Slice Zone",
        "config": {
          "choices": {
            "image_comparison": {
              "type": "SharedSlice"
            },
            "case_study": {
              "type": "SharedSlice"
            },
            "vision_statement": {
              "type": "SharedSlice"
            },
            "testimonial": {
              "type": "SharedSlice"
            },
            "team_profiles_grid": {
              "type": "SharedSlice"
            },
            "leadership_guidance": {
              "type": "SharedSlice"
            },
            "numbered_list_with_notes": {
              "type": "SharedSlice"
            },
            "call_to_action_centered": {
              "type": "SharedSlice"
            },
            "info_grid": {
              "type": "SharedSlice"
            },
            "media_feature": {
              "type": "SharedSlice"
            },
            "feature_grid": {
              "type": "SharedSlice"
            }
          }
        }
      }
    }
  }
}
