{
  "format": "custom",
  "id": "blog_article",
  "label": "Blog",
  "repeatable": true,
  "status": true,
  "json": {
    "Main": {
      "uid": {
        "type": "UID",
        "config": {
          "label": "UID"
        }
      },
      "title": {
        "type": "Text",
        "config": {
          "label": "Titre",
          "placeholder": ""
        }
      },
      "image": {
        "type": "Image",
        "config": {
          "label": "Image mise en avant",
          "constraint": {},
          "thumbnails": []
        }
      },
      "category": {
        "type": "Link",
        "config": {
          "label": "Category",
          "select": "document",
          "repeat": false,
          "customtypes": [
            {
              "id": "blog_category",
              "fields": ["name", "description", "featured_image"]
            }
          ]
        }
      },
      "slices": {
        "type": "Slices",
        "fieldset": "Slice Zone",
        "config": {
          "choices": {
            "talent_development": {
              "type": "SharedSlice"
            },
            "image_comparison": {
              "type": "SharedSlice"
            }
          }
        }
      }
    }
  }
}
